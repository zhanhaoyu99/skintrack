# ============================================
# SkinTrack Server Environment Variables
# Copy to .env and fill in actual values
# ============================================

# --- Database ---
POSTGRES_DB=skintrack
POSTGRES_USER=skintrack
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# DATABASE_URL is constructed from above, override if needed
DATABASE_URL=jdbc:postgresql://db:5432/skintrack
DATABASE_USER=skintrack
DATABASE_PASSWORD=CHANGE_ME_strong_password_here

# --- JWT ---
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64

# --- Server ---
PORT=8080
BASE_URL=https://your-domain.com
CORS_ALLOWED_HOSTS=your-domain.com

# --- Uploads ---
UPLOADS_DIR=/app/uploads

# --- Nginx / SSL ---
# Domain for SSL certificate (Let's Encrypt)
DOMAIN=your-domain.com
SSL_EMAIL=admin@your-domain.com

# --- AI Analysis (optional) ---
AI_PROVIDER=openai
AI_MODEL=gpt-4o
AI_API_KEY=
AI_MAX_DAILY_ANALYSES=10
